rules_version = '2';

// AC7 Group — Firestore Security Rules
// Requires Firebase Auth (custom token from /api/auth/login)
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(memberId) {
      return isSignedIn() && request.auth.uid == memberId;
    }

    match /members/{memberId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isOwner(memberId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["avatarUrl"])
      );
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /bin/{archiveId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
