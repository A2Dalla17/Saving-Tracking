    "jspdf-autotable": "^5.0.8",
    "lightningcss": "^1.32.0",
    "lucide-react": "^1.18.0",
    "next": "15.5.19",
    "nodemailer": "^8.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
