  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "node scripts/clean-dev.mjs && next dev -p 3000",
    "dev:win": "node scripts/ensure-lightningcss.mjs && node scripts/kill-dev-port.mjs && node scripts/clean-dev.mjs && node scripts/ensure-next-cache.mjs && next dev -p 3000",
    "build": "node scripts/prebuild.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "firebase:status": "node scripts/check-firebase.mjs",
    "firebase:normalize-env": "node scripts/normalize-env-local.mjs",
    "firebase:ensure-firestore": "node scripts/ensure-firestore.mjs",
    "firebase:deploy-rules": "npx firebase-tools deploy --only firestore:rules --project ac7-group",
    "postinstall": "node scripts/ensure-lightningcss.mjs",
    "mobile:sync": "npx cap sync",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios"
  },
  "dependencies": {
    "@genkit-ai/ai": "^1.37.0",
