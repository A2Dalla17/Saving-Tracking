# Copy to .env.local and fill in ALL three values, then SAVE the file and restart dev server.
# .env.local is gitignored — never commit it.

FIREBASE_PROJECT_ID=ac7-group
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ac7-group.iam.gserviceaccount.com
# This project uses database id "default" (not "(default)") — set if yours differs:
FIRESTORE_DATABASE_ID=default
# Paste the full private key on ONE line, wrapped in double quotes, with \n for line breaks:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_KEY_HERE\n-----END PRIVATE KEY-----\n"